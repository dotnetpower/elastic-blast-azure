# --- Azure security: prevent local artefacts from leaking secrets ---
# Working-tree elastic-blast.ini files often hold a placeholder
# `azure-storage-account-key`; the project policy is Managed Identity
# only, so block them outright.
docker-openapi/app/elastic-blast.ini
docker-openapi/app/*.log
docker-openapi/app/__pycache__/
docker-openapi/app/.env
docker-openapi/app/.env.*
